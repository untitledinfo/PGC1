# ─────────────────────────────────────────────────────────────
# PGC Admin Server — environment configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to GitHub (it's already in .gitignore).
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=production

# Comma-separated list of origins allowed to call this API
# (your live site + GitHub Pages preview + local dev)
ALLOWED_ORIGINS=https://pgcmc.fun,https://www.pgcmc.fun,https://untitledinfo.github.io,http://localhost:5500

# Admin login
ADMIN_EMAIL=admin@gmail.com
# Generate this with: npm run hash-password
# Do NOT put a plain-text password here.
ADMIN_PASSWORD_HASH=replace_with_output_of_hash-password_script

# JWT signing secret — generate a long random string, e.g.:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Gmail SMTP (for sending approval/rejection emails)
# IMPORTANT: Gmail will NOT accept your normal account password here.
# You must create a 16-character "App Password":
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Paste the 16-character code below (no spaces)
EMAIL_USER=admin@gmail.com
EMAIL_APP_PASSWORD=replace_with_16_char_google_app_password

# Cookie security (leave true in production/HTTPS)
SECURE_COOKIES=true
